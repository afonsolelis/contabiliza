PORT=3000

PGHOST=localhost
PGPORT=5432
PGDATABASE=contabiliza
PGUSER=postgres
PGPASSWORD=postgres

AUTH_USER=admin
AUTH_PASSWORD=changeme

# Provider de IA do assistente: gemini (padrão) ou nim.
AI_PROVIDER=gemini

# --- Google Gemini (provider: gemini) ---
GEMINI_API_KEY=your-gemini-api-key
# Modelo do Gemini (opcional). Padrão: gemini-2.5-flash.
# Use gemini-2.5-flash-lite para economizar a cota do free tier.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- NVIDIA NIM (provider: nim) ---
# Chave do build.nvidia.com (formato nvapi-...). Obrigatória se AI_PROVIDER=nim.
NIM_API_KEY=your-nim-api-key
# Modelo NIM (opcional). Padrão: google/gemma-3n-e4b-it.
# Modelos com function calling robusto (alternativa ao Gemma):
#   meta/llama-3.3-70b-instruct, mistralai/mistral-large-2-instruct.
NIM_MODEL=google/gemma-3n-e4b-it
# Base URL (opcional). Padrão: https://integrate.api.nvidia.com/v1.
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Telegram bot (opcional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# IDs do Telegram autorizados (separados por vírgula). Vazio = ninguém autorizado.
TELEGRAM_ALLOWED_IDS=
