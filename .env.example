PORT=3000

PGHOST=localhost
PGPORT=5432
PGDATABASE=contabiliza
PGUSER=postgres
PGPASSWORD=postgres

AUTH_USER=admin
AUTH_PASSWORD=changeme

# Google Gemini (IA)
GEMINI_API_KEY=your-gemini-api-key
# Modelo do Gemini (opcional). Padrão: gemini-2.5-flash.
# Use gemini-2.5-flash-lite para economizar a cota do free tier.
GEMINI_MODEL=gemini-2.5-flash-lite

# Telegram bot (opcional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# IDs do Telegram autorizados (separados por vírgula). Vazio = ninguém autorizado.
TELEGRAM_ALLOWED_IDS=
